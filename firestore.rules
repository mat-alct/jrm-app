rules_version = '2';

// Regras do modulo de Gestao de Projetos de Marcenaria.
// Estrutura por secao, conforme docs/gestao-projetos/PLANO.md (secao 3.2):
// - FUNDACAO: mexida apenas na branch base `feat/gestao-projetos`, seguida de merge imediato nas duas vias.
// - VIA A / VIA B: cada via edita apenas a sua secao demarcada, sempre depois de dar merge da base.
//
// Deploy: firebase deploy --only firestore:rules (requer firebase.json e login no projeto correto).
service cloud.firestore {
  match /databases/{database}/documents {

    // =========================================================
    // FUNDACAO
    // =========================================================

    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function activeUser() {
      return signedIn() && userDoc().data.active == true;
    }

    function hasRole(role) {
      return activeUser()
        && role in userDoc().data.roles;
    }

    function isAdmin() {
      return hasRole('admin');
    }

    function isSeller() {
      return hasRole('seller');
    }

    function isDesigner() {
      return hasRole('designer');
    }

    function isAssembler() {
      return hasRole('assembler');
    }

    function isWoodworker() {
      return hasRole('woodworker');
    }

    function isAssignedAssembler(projectId, itemId) {
      return isAssembler()
        && exists(/databases/$(database)/documents/projects/$(projectId)/items/$(itemId)/assemblerAssignments/$(request.auth.uid));
    }

    function isAssignedDesigner(projectId, itemId) {
      return isDesigner()
        && get(/databases/$(database)/documents/projects/$(projectId)/items/$(itemId)).data.designerId == request.auth.uid;
    }

    function updatesOnly(keys) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(keys);
    }

    function assemblerConfirmsOwnPaymentOnly() {
      return isAssembler()
        && resource.data.assemblerId == request.auth.uid
        && resource.data.status == 'pago'
        && request.resource.data.assemblerId == resource.data.assemblerId
        && request.resource.data.amount == resource.data.amount
        && request.resource.data.projectId == resource.data.projectId
        && request.resource.data.itemId == resource.data.itemId
        && request.resource.data.assignmentId == resource.data.assignmentId
        && request.resource.data.paidAt == resource.data.paidAt
        && request.resource.data.paidBy == resource.data.paidBy
        && request.resource.data.status == 'confirmado_pelo_montador';
    }

    function assemblerConfirmsOwnAssignmentOnly(assignmentId) {
      return isAssembler()
        && assignmentId == request.auth.uid
        && resource.data.assemblerId == request.auth.uid
        && resource.data.paymentStatus == 'pago'
        && request.resource.data.paymentStatus == 'confirmado_pelo_montador'
        && request.resource.data.assemblerId == resource.data.assemblerId
        && request.resource.data.amountToReceive == resource.data.amountToReceive
        && request.resource.data.projectId == resource.data.projectId
        && request.resource.data.itemId == resource.data.itemId
        && request.resource.data.assignedBy == resource.data.assignedBy
        && request.resource.data.paymentId == resource.data.paymentId;
    }

    match /users/{userId} {
      allow read: if activeUser();
      allow create, update, delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if activeUser();
      allow write: if isAdmin();
    }

    match /{path=**}/items/{itemId} {
      allow list: if isAdmin() || isSeller()
        || (isDesigner() && resource.data.get('designerId', '') == request.auth.uid);
    }

    match /{path=**}/assemblerAssignments/{assignmentId} {
      allow list: if isAdmin() || isAssembler();
    }

    // Colecoes legadas usadas pela area de cortes e pela home.
    match /orders/{orderId} {
      allow read: if activeUser();
      allow create, update: if isAdmin() || isSeller();
      allow delete: if isAdmin();
    }

    match /estimates/{estimateId} {
      allow read: if activeUser();
      allow create, update: if isAdmin() || isSeller();
      allow delete: if isAdmin();
    }

    match /materials/{materialId} {
      allow read: if activeUser();
      allow create, update, delete: if isAdmin() || isSeller();
    }

    match /sellers/{sellerId} {
      allow read: if activeUser();
      allow create, update, delete: if isAdmin();
    }

    match /counters/{counterId} {
      allow read: if activeUser();
      allow write: if isAdmin() || isSeller();
    }

    match /config/{configId} {
      allow read: if activeUser();
      allow create, update: if isAdmin()
        || (configId == 'cutting-machine' && (isSeller() || isWoodworker()));
      allow delete: if isAdmin();
    }

    match /projects/{projectId} {
      allow read: if isAdmin() || isSeller();
      allow create: if isAdmin() || isSeller();
      allow update: if isAdmin() || isSeller()
        || (activeUser() && updatesOnly(['itemSummary', 'totalCustomerValue']));
      allow delete: if isAdmin();

      match /items/{itemId} {
        // Leitura/edicao do desenhista restrita aos proprios itens (fila em /desenhista) — VIA A.
        allow get: if isAdmin() || isSeller()
          || isAssignedDesigner(projectId, itemId)
          || isAssignedAssembler(projectId, itemId);
        allow list: if isAdmin() || isSeller() || isDesigner();
        allow create: if isAdmin() || isSeller();
        allow update: if isAdmin() || isSeller()
          || isAssignedDesigner(projectId, itemId);
        allow delete: if isAdmin();

        match /attachments/{attachmentId} {
          allow read: if isAdmin() || isSeller()
            || (isAssignedDesigner(projectId, itemId)
                && resource.data.visibility in ['internal', 'client', 'designer'])
            || (isAssignedAssembler(projectId, itemId)
                && resource.data.visibility == 'assembler');
          allow create: if isAdmin() || isSeller()
            || (isAssignedDesigner(projectId, itemId)
                && request.resource.data.visibility in ['client', 'designer']
                && request.resource.data.uploadedBy == request.auth.uid
                && request.resource.data.uploadedByRole == 'designer')
            || (isAssignedAssembler(projectId, itemId)
                && request.resource.data.visibility == 'assembler'
                && request.resource.data.uploadedBy == request.auth.uid
                && request.resource.data.uploadedByRole == 'assembler');
          allow update, delete: if isAdmin();
        }

        match /statusHistory/{historyId} {
          allow read: if isAdmin() || isSeller();
          allow create: if activeUser();
          allow update, delete: if false;
        }

        // === VIA A ===
        // Desenhista le/atualiza apenas itens atribuidos a ele; cria as proprias versoes.
        match /versions/{versionId} {
          allow read: if isAdmin() || isSeller()
            || (isDesigner() && get(/databases/$(database)/documents/projects/$(projectId)/items/$(itemId)).data.designerId == request.auth.uid);
          allow create: if isAdmin()
            || (isDesigner() && get(/databases/$(database)/documents/projects/$(projectId)/items/$(itemId)).data.designerId == request.auth.uid);
          allow update, delete: if isAdmin();
        }
        // === FIM VIA A ===

        // === VIA B ===
        // Montador le apenas as proprias atribuicoes; nunca edita amountToReceive (so o admin).
        match /assemblerAssignments/{assignmentId} {
          allow read: if isAdmin()
            || (isAssembler()
                && assignmentId == request.auth.uid
                && resource.data.assemblerId == request.auth.uid);
          allow create, delete: if isAdmin();
          allow update: if isAdmin()
            || assemblerConfirmsOwnAssignmentOnly(assignmentId);
        }
        // === FIM VIA B ===
      }
    }

    // === VIA B ===
    // Pagamentos: admin ve tudo; montador ve e confirma apenas os proprios.
    match /payments/{paymentId} {
      allow read: if isAdmin()
        || (isAssembler() && resource.data.assemblerId == request.auth.uid);
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || assemblerConfirmsOwnPaymentOnly();
    }
    // === FIM VIA B ===

    // O cliente (nao autenticado) nunca le o Firestore diretamente — todo acesso
    // do portal do cliente passa pelas API routes server-side (spec secao 20).
  }
}
