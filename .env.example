# FIREBASE - CLIENT SIDE (público, embute no bundle)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# FIREBASE - SERVER SIDE (segredos, somente server)
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# GESTAO DE PROJETOS - PORTAL DO CLIENTE (segredo, somente server)
# Usado para assinar o cookie de sessao do cliente (HMAC). Gere um valor
# aleatorio longo, ex.: `openssl rand -hex 32`.
CLIENT_ACCESS_SECRET=
